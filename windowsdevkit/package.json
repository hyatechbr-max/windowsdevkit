{
  "name": "windowsdevkit",
  "displayName": "WindowsDevKit",
  "description": "Detects Linux/Mac commands in the terminal and editor and shows the Windows equivalent automatically.",
  "version": "1.1.0",
  "publisher": "windowsdevkit",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": ["Other", "Linters"],
  "keywords": ["windows", "linux", "terminal", "commands", "developer tools", "powershell", "compatibility"],
  "icon": "icon.png",
  "activationEvents": ["onStartupFinished"],
  "enabledApiProposals": ["terminalDataWriteEvent"],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "windowsdevkit.traduzir",
        "title": "WindowsDevKit: Translate commands to Windows",
        "category": "WindowsDevKit"
      },
      {
        "command": "windowsdevkit.verificar",
        "title": "WindowsDevKit: Check current file",
        "category": "WindowsDevKit"
      },
      {
        "command": "windowsdevkit.historico",
        "title": "WindowsDevKit: Show terminal history",
        "category": "WindowsDevKit"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "windowsdevkit.traduzir",
          "group": "windowsdevkit",
          "when": "editorIsOpen"
        },
        {
          "command": "windowsdevkit.verificar",
          "group": "windowsdevkit",
          "when": "editorIsOpen"
        }
      ]
    },
    "keybindings": [
      {
        "command": "windowsdevkit.traduzir",
        "key": "ctrl+shift+w",
        "when": "editorIsOpen"
      }
    ],
    "configuration": {
      "title": "WindowsDevKit",
      "properties": {
        "windowsdevkit.enableDecorations": {
          "type": "boolean",
          "default": true,
          "description": "Automatically underline detected Linux commands in the editor"
        },
        "windowsdevkit.monitorTerminal": {
          "type": "boolean",
          "default": true,
          "description": "Monitor the terminal and alert when a Linux command fails"
        }
      }
    }
  },
  "scripts": {
    "package": "vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.22.0"
  }
}
